# Logs directory: ONLY (id).json log files. No state or skip list here.
# Docker: compose mounts ./logs to /app/logs.
LOGS_DIR=./logs

# Downloader state directory: downloader_state.json and skipped_log_ids.json (separate from LOGS_DIR).
# Docker: compose mounts ./downloader_state to /app/downloader_state.
DOWNLOADER_STATE_DIR=./downloader_state

# Request log CSV; keep separate from LOGS_DIR.
# Docker: compose mounts ./request_logs to /app/request_logs and sets REQUEST_LOG_PATH=/app/request_logs/request_log.csv.
# Local run: use an absolute path, e.g. /path/to/Tf2LogSearcher/request_logs/request_log.csv
REQUEST_LOG_PATH=./request_logs/request_log.csv

# Chat SQLite DB file (created/updated by downloader and backfill script).
# Keep it on a persistent volume path.
CHAT_DB_PATH=./downloader_state/chat.db

# SQLite DB for Steam avatar URL cache (web app only).
AVATAR_DB_PATH=./downloader_state/avatars.db

# SQLite DB for per-log player stats (populated by downloader and backfill script).
STATS_DB_PATH=./downloader_state/stats.db

# logs.tf API base (no trailing slash)
LOGS_TF_API_BASE=https://logs.tf

# Steam Web API key (optional). Required to resolve vanity URLs/names to SteamID64.
# Get one at https://steamcommunity.com/dev/apikey — never exposed to the frontend or API responses.
STEAM_WEB_API_KEY=

# Downloader: seconds between full cycles
DOWNLOAD_INTERVAL_SEC=3600

# Downloader rate limiting (logs.tf is fragile)
REQUEST_DELAY_MS=300
MAX_REQUESTS_BEFORE_BACKOFF=1500
BACKOFF_SEC=60
RETRY_ATTEMPTS=3

# Web app rate limiting (per-IP sliding window, independent of downloader limits above).
# RATE_LIMIT_PROFILE_PER_MINUTE: max profile API requests per IP per window (default 10).
# RATE_LIMIT_LEADERBOARD_PER_MINUTE: max leaderboard API requests per IP per window (default 10).
# RATE_LIMIT_WINDOW_SECONDS: window length in seconds (default 60).
# RATE_LIMIT_MAX_TRACKED_IPS: max distinct IPs tracked in memory before LRU eviction (default 50000).
# Set RATE_LIMIT_PROFILE_PER_MINUTE=0 (minimum enforced at 1) to keep the default;
# there is no way to disable the limiter entirely without removing the check in routes.py.
RATE_LIMIT_PROFILE_PER_MINUTE=10
RATE_LIMIT_LEADERBOARD_PER_MINUTE=10
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_TRACKED_IPS=50000
